<style>
  /* 确保备案链接在移动设备上正常显示 */
  @media (max-width: 640px) {
    .text-center:last-of-type p {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
    }
    .text-center:last-of-type span.mx-2 {
      display: none;
    }
  }
</style>
